# URL pública da aplicação
NEXT_PUBLIC_APP_URL=https://cyberregistro.vercel.app

# Shopee Open Platform (partner_id / partner_key do painel de desenvolvedor Shopee)
# Autenticação da Shopee usa assinatura HMAC-SHA256 (não é OAuth Bearer simples
# como o Mercado Livre) + access_token/refresh_token por LOJA (shop_id).
SHOPEE_PARTNER_ID=seu_partner_id_shopee
SHOPEE_PARTNER_KEY=sua_partner_key_shopee
SHOPEE_REDIRECT_URI=https://www.cyberregistro.com.br/api/auth/shopee/callback
